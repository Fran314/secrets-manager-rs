#!/usr/bin/env bash
# secs-man-ssh: drive secs-man import/export against a remote machine that has
# SSH root login disabled and a root-owned secrets dir, WITHOUT ever sending
# the encryption passphrase to the remote.
#
# Crypto (encrypt/decrypt, needs the passphrase) runs locally. The remote only
# does root-owned filesystem work, over the already-encrypted SSH transport.
# The passphrase never leaves the local machine.
#
# Both import and export have a temporary inevitable leak: in order to copy the
# secrets over SSH without root login, the files have to temporarily be
# readable by the non-root user. The temporary files gets deleted as soon as
# they are used, limiting the leakage window. If this threat model is
# problematic, one can opt to copy over SSH the encrypted snapshot instead of
# of the plaintext secrets, at the cost of having to pass the passphrase to the
# remote over SSH. However this script does not implement this alternative
# flow.
#
# Prerequisites:
#   - secs-man on the local PATH (both directions).
#   - secs-man on the remote, matching the remote CPU arch, reachable on root's
#     PATH since sudo runs it (only for import, export's remote step is pure cp+chown).
#   - The SSH target user can sudo on the remote.
#   - rsync on both ends.
#
# Usage:
#   secs-man-ssh export <user@host> <remote-secrets-dir> <local-container>
#   secs-man-ssh import <user@host> <local-container> <remote-secrets-dir>
#
# export: back up the remote's secrets into the local container, encrypting
#         locally (a new timestamped snapshot is created in <local-container>).
# import: restore the newest snapshot from the local container onto the remote,
#         decrypting locally and applying the manifest's owner/mode on the remote.

set -euo pipefail

error() {
    echo "secs-man-ssh: $*" >&2
    exit 1
}

usage() {
    {
        echo "usage:"
        echo "  secs-man-ssh export <user@host> <remote-secrets-dir> <local-container>"
        echo "  secs-man-ssh import <user@host> <local-container> <remote-secrets-dir>"
    } >&2

    exit 2
}

[ $# -eq 4 ] || usage
subcommand=$1
ssh_target=$2

case "$subcommand" in
export)
    remote_secrets=$3
    local_container=$4
    ;;
import)
    local_container=$3
    remote_secrets=$4
    ;;
*) usage ;;
esac

local_stg=
remote_stg=

# Each staging dir is removed the moment its plaintext has been consumed, to
# minimize the leakage window. cleanup() is the safety net for the failure paths.
remove_local_stg() {
    if [ "$local_stg" != "" ]; then
        rm -rf -- "$local_stg"
        local_stg=
    fi
}
remove_remote_stg() {
    if [ "$remote_stg" != "" ]; then
        # $remote_stg is meant to expand client-side: the remote gets the literal path.
        # shellcheck disable=SC2029
        ssh "$ssh_target" "rm -rf -- '$remote_stg'" ||
            echo "secs-man-ssh: warning: could not remove remote staging '$remote_stg' (may need manual sudo cleanup)" >&2
        remote_stg=
    fi
}
cleanup() {
    remove_local_stg
    remove_remote_stg
}
trap cleanup EXIT

local_stg=$(mktemp -d)
remote_stg=$(ssh "$ssh_target" 'mktemp -d')
[ "$remote_stg" != "" ] || error "failed to create remote staging dir"

if [[ "$subcommand" == "export" ]]; then
    echo "Staging remote secrets..."
    ssh -t "$ssh_target" \
        "sudo -p '[sudo] password for $ssh_target: ' sh -c 'cp -a -- \"$remote_secrets/.\" \"$remote_stg/\" && chown -R -- \"\$SUDO_USER\" \"$remote_stg\"'"

    echo "Fetching staged secrets..."
    rsync -a "$ssh_target:$remote_stg/" "$local_stg/"
    remove_remote_stg

    echo "Encrypting locally..."
    secs-man export "$local_stg" "$local_container"
    remove_local_stg

elif [[ "$subcommand" == "import" ]]; then
    echo "Decrypting locally..."
    secs-man import --skip-chown-chmod "$local_container" "$local_stg"

    echo "Uploading plaintext staging..."
    rsync -a "$local_stg/" "$ssh_target:$remote_stg/"
    remove_local_stg

    echo "Applying on remote..."
    ssh -t "$ssh_target" \
        "sudo -p '[sudo] password for $ssh_target: ' secs-man import --from-plaintext -- \"$remote_stg\" \"$remote_secrets\""
    remove_remote_stg
fi
